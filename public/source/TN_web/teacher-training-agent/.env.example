# 复制为 .env.local 后填写（勿将 .env.local 提交到 Git）

# ===== 部署（生产构建 npm run build）=====
# 解决「Failed to resolve module specifier vue」：必须部署 dist 目录，不要直接把含 src/ 的源码当静态站。
# 构建命令：npm ci && npm run build，再把 dist/ 内全部文件上传为站点根或子目录。
# 静态资源 base 在 vite.config.js 中为 ./；若必须固定绝对子路径，请改 vite.config.js 的 base。

# ===== 专项模拟（主对话）=====
VITE_SPECIAL_BOT_APP_KEY=
VITE_SPECIAL_WORKFLOW_DEBUG=true
# false = 工作流无返回时不使用本地模拟学生回复；工作流返回的正文仍会正常显示
VITE_SPECIAL_AUTO_APPEND_REPLY=true
# VITE_SPECIAL_VISITOR_BIZ_ID=teacher-001
# VITE_SPECIAL_PROXY_URL=http://127.0.0.1:8787/lke/sse
# VITE_SPECIAL_ENDPOINT=https://wss.lke.cloud.tencent.com/v1/qbot/chat/sse

# ===== 训练报告（直连 HTTP，不再走腾讯云 SSE）=====
# 浏览器实际请求的地址。开发时若填 https 外域会触发 CORS，已自动改为走 /api/report 代理，此项在 dev 下可省略
# VITE_REPORT_HTTP_URL=/api/report
# 代理目标（仅 Vite dev / vite preview）：/api/report 转发到 目标主机 + 下方路径
# VITE_REPORT_PROXY_TARGET=https://agent.orangeblog.us.kg:8000
# 上游路径；默认 /（根路径）。若后端挂在子路径再设，例如 /api/chat
# VITE_REPORT_PROXY_PATH=/
# 生产构建若仍直连外域且遇 CORS，请把站点根路径反代到该 API，并把 VITE_REPORT_HTTP_URL 设为同源路径
# 直连后端基址（无尾斜杠）；不设时生产默认 https://agent.orangeblog.us.kg:8000
# VITE_REPORT_HTTP_URL=https://agent.orangeblog.us.kg:8000
# 必填；会打进前端包，浏览器可见，生产建议由自有后端代发
# 报告请求为 POST：Chat Completions 形；仅标准字段，不含对话/情绪等训练数据
# 请求头 Authorization: Bearer；JSON 内可含 api_key（见 workflow.js）
# VITE_REPORT_HTTP_API_KEY=
# 报告里 user 消息的固定文案（默认：请生成教学训练报告。）
# VITE_REPORT_USER_MESSAGE=
# 可选：覆盖 model（否则用当前学生名，再默认「李大志」）
# VITE_REPORT_CHAT_MODEL=李大志
# VITE_REPORT_CHAT_TEMPERATURE=0.8
# VITE_REPORT_CHAT_TOP_P=0.95
# VITE_REPORT_CHAT_MAX_TOKENS=512
# VITE_REPORT_CHAT_STREAM=false
# VITE_REPORT_CHAT_USER=teacher_session_1
# VITE_REPORT_WORKFLOW_DEBUG=true
#
# （旧）训练报告独立 Bot，已不使用时可留空
# VITE_REPORT_BOT_APP_KEY=
# VITE_REPORT_VISITOR_BIZ_ID=teacher-001
# VITE_REPORT_PROXY_URL=http://127.0.0.1:8787/lke/sse
# VITE_REPORT_ENDPOINT=https://wss.lke.cloud.tencent.com/v1/qbot/chat/sse

# ===== 课堂模拟（独立 Bot）=====
VITE_CLASSROOM_BOT_APP_KEY=
VITE_CLASSROOM_WORKFLOW_DEBUG=true
# VITE_CLASSROOM_VISITOR_BIZ_ID=classroom_teacher_001
# VITE_CLASSROOM_PROXY_URL=http://127.0.0.1:8787/lke/sse
# VITE_CLASSROOM_ENDPOINT=https://wss.lke.cloud.tencent.com/v1/qbot/chat/sse
